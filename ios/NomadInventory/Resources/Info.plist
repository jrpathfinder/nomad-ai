<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Camera permission — required for scanning items -->
    <key>NSCameraUsageDescription</key>
    <string>NomadInventory uses the camera to photograph and identify your belongings.</string>

    <!-- Photo library permission — for picking existing photos -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>NomadInventory reads your photo library so you can attach existing photos to items.</string>

    <!-- Anthropic API key — replace with your key or inject via CI/CD -->
    <key>ANTHROPIC_API_KEY</key>
    <string>$(ANTHROPIC_API_KEY)</string>

    <!-- Standard keys -->
    <key>CFBundleName</key>
    <string>NomadInventory</string>
    <key>CFBundleDisplayName</key>
    <string>Nomad Inventory</string>
    <key>CFBundleIdentifier</key>
    <string>com.nomad.inventory</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>MinimumOSVersion</key>
    <string>17.0</string>
</dict>
</plist>
